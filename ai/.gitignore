# =========================================================================
# ☕ 後端 (Spring Boot / Maven) 忽略項目
# =========================================================================
# 忽略編譯產出的 target 資料夾與執行暫存檔
backend/target/
backend/.mvn/
backend/mvnw
backend/mvnw.cmd

# 忽略 IntelliJ IDEA 的環境設定檔
backend/.idea/
backend/*.iml
backend/.settings/
backend/.project/
backend/.classpath/


# =========================================================================
# 📦 前端 (Vue / Node.js) 忽略項目
# =========================================================================
# 絕對不要把幾十萬個檔案的 node_modules 推上去！
frontend/node_modules/

# 忽略前端打包編譯出來的產物 dist
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# 忽略 VS Code 本地的編輯器設定資料夾
.vscode/


# =========================================================================
# 💻 系統快取垃圾
# =========================================================================
.DS_Store
Thumbs.db
*.env